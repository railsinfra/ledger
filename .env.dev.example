# Ledger service — local development
# Copy to `.env` and replace placeholders:
#   cp .env.dev.example .env

DATABASE_URL=postgresql://localhost:5432/ledger_development
PORT=3000
GRPC_PORT=50053
RAILS_ENV=development

# Generate a value, e.g. `bin/rails secret` or `openssl rand -hex 64`
SECRET_KEY_BASE=replace_me_with_a_long_random_string

# Must match the JWT issuer (for example the users service) for validating read APIs in shared environments.
# Development falls back to a default if unset; set explicitly to mirror production.
JWT_SECRET=replace_me_shared_with_token_issuer

# Optional error reporting
SENTRY_DSN=

# Set to `0` to skip starting the embedded gRPC server (see config/initializers/grpc.rb)
# START_GRPC_SERVER=1
